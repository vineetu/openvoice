*.xcuserdatad/
*.xcuserstate
DerivedData/
build/
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
Packages/
# Note: Package.resolved IS committed (not ignored)

# Distribution output
dist/

# Secrets / credentials (defensive — none should be in repo)
.env
*.p12
*.p8
*.pem
*.key
*.cer

# Flavor-specific build config — never committed
.flavor-*.env
.flavor-*.overrides

# Docs not for public repo
docs/plans/
docs/research/
docs/screenshot/
docs/spike-results/
docs/task-breakdown-phase1.md

# Pre-flight spike packages (standalone tests)
Spikes/

# iOS work-in-progress — not ready to ship, committed in a later release
iOS/

# Grounding-doc pipeline (spec v5 §11) — fragments and concatenated doc
# are regenerated on every build from help-content-base.md + Swift enums.
# Keep the base prose checked in; ignore the derived outputs.
Resources/fragments/
Resources/help-content.md

# Private flavor sources (e.g. flavor_1 / PFB Enterprise) — only present
# on internal machines that source a `.flavor-*.env` at release time.
Sources/Private/

# Flavor-1 internal features doc — mirrors docs/features.md layout but
# covers tenant-specific surfaces that must not ship on public `main`.
docs/features-flavor1.md

# Sony-internal announcement / share copy — not for the public remote.
docs/sony-announce.md

# scripts/agent-verify.sh per-stage build/test logs — large outputs
# kept around for one run for debugging; never want them committed.
.agent-verify-logs/
