        "ja" : { "stringUnit" : { "state" : "new", "value" : "" } }
      }
    },
    "No hard time limit — dictate for as long as you need. Quality gradually diminishes for recordings longer than about an hour, so shorter sessions work best." : {
      "comment" : "Help Basics — Any-length recordings sub-row prose",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No hard time limit — dictate for as long as you need. Quality gradually diminishes for recordings longer than about an hour, so shorter sessions work best." } },
        "ja" : { "stringUnit" : { "state" : "new", "value" : "" } }
      }
    },
    "Parakeet TDT 0.6B v3 runs on the Apple Neural Engine via FluidAudio. Audio never leaves the Mac. The model downloads on first use, about 600 MB." : {
      "comment" : "Help Basics — On-device transcription sub-row prose",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Parakeet TDT 0.6B v3 runs on the Apple Neural Engine via FluidAudio. Audio never leaves the Mac. The model downloads on first use, about 600 MB." } },
        "ja" : { "stringUnit" : { "state" : "new", "value" : "" } }
      }
    },
    "Parakeet auto-detects the language on each recording. Supported today:" : {
      "comment" : "Help Basics — Multilingual sub-row prose preceding the language grid",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Parakeet auto-detects the language on each recording. Supported today:" } },
        "ja" : { "stringUnit" : { "state" : "new", "value" : "" } }
      }
    },
    "Two transcription models. English (Parakeet v3) auto-detects 25 European languages — installed by default. Japanese (Parakeet 0.6B JA) is a separate ~1.25 GB download. Pick one as primary at Settings → Transcription; only the primary is hot in memory." : {
      "comment" : "Help Basics — Languages sub-row prose",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Two transcription models. English (Parakeet v3) auto-detects 25 European languages — installed by default. Japanese (Parakeet 0.6B JA) is a separate ~1.25 GB download. Pick one as primary at Settings → Transcription; only the primary is hot in memory." } },
        "ja" : { "stringUnit" : { "state" : "new", "value" : "" } }
      }
    },
    "Custom Vocabulary applies only to European-language transcription. The Japanese model uses a different tokenizer, so vocabulary boosts are not applied when Japanese is primary." : {
      "comment" : "Help Basics — Languages sub-row warning",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Custom Vocabulary applies only to European-language transcription. The Japanese model uses a different tokenizer, so vocabulary boosts are not applied when Japanese is primary." } },
        "ja" : { "stringUnit" : { "state" : "new", "value" : "" } }
      }
    },
    "Vocabulary entries override similar-sounding words. Adding many entries that sound alike causes unpredictable preference among them. Keep the list focused." : {
      "comment" : "Help Basics — Custom vocabulary warning",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Vocabulary entries override similar-sounding words. Adding many entries that sound alike causes unpredictable preference among them. Keep the list focused." } },
        "ja" : { "stringUnit" : { "state" : "new", "value" : "" } }
      }
    },
    "Pick who does the AI work. Apple Intelligence is the default on macOS 26+ — on-device, private, free, but quality for Cleanup trails cloud today. Cloud providers (OpenAI, Anthropic, Gemini) deliver strong results with your own API key. Ollama runs locally." : {
      "comment" : "Help Basics — Cleanup providers sub-row prose",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Pick who does the AI work. Apple Intelligence is the default on macOS 26+ — on-device, private, free, but quality for Cleanup trails cloud today. Cloud providers (OpenAI, Anthropic, Gemini) deliver strong results with your own API key. Ollama runs locally." } },
        "ja" : { "stringUnit" : { "state" : "new", "value" : "" } }
      }
    },
    "The default cleanup prompt removes fillers, fixes grammar and punctuation, and preserves your voice. Power users can rewrite it; a reset-to-default restores the shipped version." : {
      "comment" : "Help Basics — Cleanup editable prompt sub-row prose",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The default cleanup prompt removes fillers, fixes grammar and punctuation, and preserves your voice. Power users can rewrite it; a reset-to-default restores the shipped version." } },
        "ja" : { "stringUnit" : { "state" : "new", "value" : "" } }
